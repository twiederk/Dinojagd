{
  "$schema": "https://claude.ai/.claude/schema/settings.json",
  "project": {
    "name": "Dinojagd",
    "description": "2D Action-Adventure Godot 4.6 Game",
    "version": "1.3.0"
  },
  "codeContext": {
    "primaryLanguage": "gdscript",
    "gameEngine": "godot-4.6",
    "styleguide": {
      "naming": "snake_case for functions, PascalCase for classes",
      "conventions": "See godot-conventions skill",
      "targetProfile": "Game Development"
    }
  },
  "assistantBehavior": {
    "codeStyle": "idiomatic",
    "explainComplexity": true,
    "suggestRefactoring": true,
    "prioritizePerformance": true,
    "prioritizeGameDesign": true
  },
  "customization": {
    "skillsPath": ".claude/skills",
    "agentsPath": ".claude/agents",
    "commandsPath": ".claude/commands"
  }
}
